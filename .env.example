# =============================================================================
# Lushop Chatbot Environment Variables
# =============================================================================

# LLM Provider API Keys (at least one recommended)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# gRPC downstream service addresses
GOODS_SERVICE_ADDR=localhost:50052
ORDER_SERVICE_ADDR=localhost:50053
USER_SERVICE_ADDR=localhost:50051
INVENTORY_SERVICE_ADDR=localhost:50054

# Goods search backend: es or grpc
GOODS_SEARCH_BACKEND=es

# Elasticsearch settings (used when GOODS_SEARCH_BACKEND=es)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=goods

# MySQL analytics (optional; required for aggregate metrics)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lushop
# Optional fallback scan list, comma-separated (e.g. aidoc,lushop)
MYSQL_DATABASES=

# RAG knowledge retrieval
RAG_PROMPTS_DIR=src/prompts

# MCP JSON-RPC gateway (optional)
MCP_HTTP_ENDPOINT=http://127.0.0.1:9000/mcp

# Third-party webhook (optional)
THIRD_PARTY_WEBHOOK_URL=
THIRD_PARTY_WEBHOOK_TOKEN=

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lushop-chatbot
