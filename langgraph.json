{
  "dependencies": ["."],
  "graphs": {
    "customer_service": "./src/agent/customer_service.py:customer_service_agent",
    "user_analyst": "./src/agent/user_analyst.py:user_analyst"
  },
  "env": ".env",
  "image_distro": "wolfi",
